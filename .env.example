# ============================================================
# .env.example — Copy to .env and fill in your credentials
# ============================================================

# ─── NADO (Ink Blockchain) ───────────────────────────────────
NADO_PRIVATE_KEY=0x...
NADO_SUBACCOUNT_OWNER=0x...          # only if using linked signer
NADO_ENV=nadoMainnet                  # nadoMainnet | nadoTestnet
NADO_SUBACCOUNT_NAME=default

# ─── DECIBEL (Aptos Blockchain) ──────────────────────────────
DECIBEL_PRIVATE_KEY=0x...            # Aptos Ed25519 private key
DECIBEL_SUBACCOUNT_ADDR=0x...        # your Decibel subaccount address
DECIBEL_GEOMI_KEY=aptoslabs_...     # Bearer token from https://geomi.dev (required!)
DECIBEL_ENV=mainnet                   # mainnet | testnet

# ─── RISE TRADE (Rise Chain / EVM) ───────────────────────────
RISE_PRIVATE_KEY=0x...               # EVM private key
RISE_API_KEY=                         # if required
RISE_RPC_URL=https://mainnet.riselabs.xyz
RISE_ENV=mainnet                      # mainnet | testnet

# ─── BOT CONFIG ──────────────────────────────────────────────
DEFAULT_EXCHANGE=nado
LOG_LEVEL=INFO
DB_PATH=./bot_trade.db

# Risk Management
MAX_POSITION_USD=1000                 # max total position size in USD
MAX_DRAWDOWN_PCT=5.0                  # stop bot if drawdown exceeds this %
MAX_LEVERAGE=5                        # max leverage per position

# Funding Arb Config
MIN_FUNDING_DIFF=0.01                 # minimum funding rate diff (%) to trigger arb
FUNDING_CHECK_INTERVAL=60             # seconds between funding rate checks
